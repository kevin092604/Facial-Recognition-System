# Configuración de la base de datos SQL Server
# Copiar este archivo como .env y ajustar los valores

# Servidor SQL Server (ej: localhost, 192.168.1.100, MYPC\\SQLEXPRESS)
DB_SERVER=localhost

# Nombre de la base de datos
DB_NAME=UNAH_AccessControl

# Autenticación SQL (dejar vacío si se usa autenticación de Windows)
DB_USER=sa
DB_PASSWORD=tu_password_aqui

# Driver ODBC instalado en el sistema
# Opciones: "ODBC Driver 17 for SQL Server" o "ODBC Driver 18 for SQL Server"
DB_DRIVER=ODBC Driver 17 for SQL Server

# Usar autenticación de Windows (yes/no)
# Si es "yes", se ignoran DB_USER y DB_PASSWORD
DB_TRUSTED_CONNECTION=no

# Puerto del servidor (8000 por defecto)
PORT=8000

# Orígenes CORS permitidos (separados por coma)
# En producción, agregar las IPs/dominios de las terminales
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
